{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Workflow Definition",
  "description": "Declarative workflow for agent routing sequences",
  "type": "object",
  "required": ["workflow_version", "name", "description", "scope", "steps", "gates_required"],
  "properties": {
    "workflow_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Workflow schema version"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Human-readable workflow name"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "What this workflow does"
    },
    "scope": {
      "type": "string",
      "enum": ["quick", "medium", "large"],
      "description": "Change scope for spec artifact sizing"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["agent", "gate_after"],
        "properties": {
          "agent": {
            "type": "string",
            "enum": ["scout", "sage", "forge", "ward", "arbiter"]
          },
          "gate_after": {
            "type": "string",
            "enum": ["G0", "G1", "G4", "G5", "G6"]
          },
          "skip_on": {
            "type": "string",
            "description": "Condition expression for skipping step"
          }
        }
      }
    },
    "spec_artifacts": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Files Sage must write for this scope"
    },
    "gates_required": {
      "type": "array",
      "items": { "type": "string", "enum": ["G0", "G1", "G4", "G5", "G6"] },
      "description": "Gates always enforced"
    },
    "gates_optional": {
      "type": "array",
      "items": { "type": "string", "enum": ["G4", "G5"] },
      "description": "Gates offered to user for opt-in"
    }
  }
}
